# Environment Variables Template
# Copy this file to .env.local and fill in your values

# Site Configuration
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_NAME="Coffee Roaster"

# API Keys (if needed)
# NEXT_PUBLIC_API_KEY=your_api_key_here

# Analytics (optional)
# NEXT_PUBLIC_GA_MEASUREMENT_ID=G-XXXXXXXXXX
# NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# Email Service (optional)
# SENDGRID_API_KEY=your_sendgrid_api_key
# EMAIL_FROM=noreply@coffeeroaster.com
# EMAIL_TO=admin@coffeeroaster.com

# Payment Gateway (optional)
# STRIPE_PUBLIC_KEY=pk_test_xxxxxxxxxxxx
# STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx

# CMS (optional)
# CONTENTFUL_SPACE_ID=your_space_id
# CONTENTFUL_ACCESS_TOKEN=your_access_token

# Social Media Links (optional)
# NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/coffeeroaster
# NEXT_PUBLIC_FACEBOOK_URL=https://facebook.com/coffeeroaster
# NEXT_PUBLIC_TWITTER_URL=https://twitter.com/coffeeroaster

# Feature Flags
NEXT_PUBLIC_ENABLE_SUBSCRIPTION=false
NEXT_PUBLIC_ENABLE_SHOP=false
NEXT_PUBLIC_ENABLE_BLOG=false