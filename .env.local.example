# =============================================================================
# SANITY CMS (Required)
# Get these from https://sanity.io/manage
# =============================================================================
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-01-01
SANITY_API_READ_TOKEN=

# =============================================================================
# SEED SCRIPT (Required for npm run seed)
# =============================================================================
SANITY_API_WRITE_TOKEN=

# =============================================================================
# CONTACT FORM (Required for contact page)
# =============================================================================
# Resend: https://resend.com/api-keys
RESEND_API_KEY=
CONTACT_EMAIL_TO=hello@yourbusiness.com
CONTACT_EMAIL_FROM=noreply@yourbusiness.com

# =============================================================================
# OPTIONAL
# =============================================================================
NEXT_PUBLIC_SITE_URL=https://yourbusiness.com
NEXT_PUBLIC_GA_ID=
